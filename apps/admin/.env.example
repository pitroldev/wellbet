# ─── Charya admin — variáveis de ambiente ───
# Copie para `.env.local` (dev) e preencha. Validadas no boot via @charya/env (t3-env).
# Nunca commitar segredos reais.

# URL pública da API (NestJS). Usada pelo cliente tipado de @charya/contracts.
# Porta unificada no repo: a api roda em :3000.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Better Auth — sessão compartilhada com a API (mesmo emissor, porta :3000).
# Em produção apontar para a origem do serviço de auth.
NEXT_PUBLIC_AUTH_URL=http://localhost:3000
BETTER_AUTH_URL=http://localhost:3000
# Segredo de assinatura de sessão (mesmo valor da API). >= 32 chars.
BETTER_AUTH_SECRET=change-me-in-prod-min-32-characters-long

# Node
NODE_ENV=development

# Variáveis públicas do app Expo. Tudo que começa com EXPO_PUBLIC_ é embutido
# no bundle (NÃO colocar segredos aqui). Segredos ficam no EAS / secret manager.

# Base da API (cliente tipado de @charya/contracts).
EXPO_PUBLIC_API_URL=http://localhost:3000

# Ambiente lógico (development | staging | production).
EXPO_PUBLIC_ENV=development

# Endpoint público do R2 (apenas para leitura/preview; upload é via URL
# pré-assinada emitida pela API, nunca com credencial no app).
EXPO_PUBLIC_R2_PUBLIC_URL=https://media.charya.dev

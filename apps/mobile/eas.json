{
  "$schema": "https://json.schemastore.org/eas.json",
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "//": "Três perfis (§8.3). 'development' = dev client p/ rodar nativo local; 'preview' = build interno distribuível p/ QA (canal staging); 'production' = build de loja (canal production). channel liga o build ao branch de EAS Update (OTA).",
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "simulator": true
      },
      "env": {
        "EXPO_PUBLIC_ENV": "development"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "staging",
      "ios": {
        "simulator": false
      },
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_ENV": "staging"
      }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_ENV": "production"
      }
    }
  },
  "submit": {
    "//": "Perfis de submit usados por cd-mobile.yml (eas submit --profile ...). Os IDs reais (ascAppId, serviceAccountKeyPath, track) vêm de secrets/arquivos do EAS, não versionados aqui.",
    "preview": {
      "ios": {
        "ascAppId": "REPLACE_WITH_APP_STORE_CONNECT_APP_ID"
      },
      "android": {
        "track": "internal",
        "releaseStatus": "draft"
      }
    },
    "production": {
      "ios": {
        "ascAppId": "REPLACE_WITH_APP_STORE_CONNECT_APP_ID"
      },
      "android": {
        "track": "production",
        "releaseStatus": "draft"
      }
    }
  }
}

# ─── WellBet landing — variáveis de ambiente ───
# Copie para `.env.local` (dev) e preencha. Apenas variáveis PÚBLICAS
# (prefixo NEXT_PUBLIC_): a landing é estática/marketing e não tem segredos.
# Nunca commitar valores reais aqui.

# Origem pública da landing — usada para canonical/OpenGraph (URLs absolutas).
# Em produção, o domínio final da landing.
NEXT_PUBLIC_SITE_URL=https://wellbet.com.br

# URL do app (download / abrir o app) para onde os CTAs apontam.
NEXT_PUBLIC_APP_URL=https://app.wellbet.com.br

# Node
NODE_ENV=development

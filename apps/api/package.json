{
  "name": "@charya/api",
  "version": "0.0.0",
  "private": true,
  "description": "Charya Bet — backend NestJS (modular por feature + ports & adapters)",
  "type": "module",
  "exports": {
    ".": "./dist/main.js"
  },
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build && tsc-alias -p tsconfig.build.json",
    "dev": "pnpm build && concurrently -k -n nest,alias,run \"nest build --watch\" \"tsc-alias -w -p tsconfig.build.json\" \"node --watch dist/main.js\"",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "openapi:emit": "node dist/openapi-emit.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "contracts:generate": "openapi-ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@charya/env": "workspace:*",
    "@charya/schemas": "workspace:*",
    "@nestjs/common": "^11.1.0",
    "@nestjs/core": "^11.1.0",
    "@nestjs/platform-express": "^11.1.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.219.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "better-auth": "^1.6.14",
    "drizzle-orm": "1.0.0-rc.3",
    "drizzle-zod": "^0.8.0",
    "helmet": "^8.0.0",
    "nestjs-pino": "^4.0.0",
    "nestjs-zod": "^5.0.0",
    "pg": "^8.13.0",
    "pg-boss": "^12.19.0",
    "pino": "^9.0.0",
    "pino-http": "^10.0.0",
    "pino-opentelemetry-transport": "^3.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "starkbank": "^2.40.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@hey-api/openapi-ts": "^0.98.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.0",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^7.0.0",
    "concurrently": "^10.0.3",
    "drizzle-kit": "1.0.0-rc.3",
    "eslint": "catalog:",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.0.0",
    "tsc-alias": "^1.8.17",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "catalog:"
  }
}

  "info": {
    "title": "Charya API",
    "description": "Backend Charya Bet — pesagem, desafio, revisão, aposta.",
    "version": "0.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "better-auth.session_token"
      }
    },
    "schemas": {
      "MeResponseDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email",
            "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$"
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "role": {
            "type": "string",
            "enum": [
              "user",
              "reviewer",
              "admin"
            ]
          },
          "taxId": {
            "type": "string",
            "nullable": true
          },
          "pixKey": {
            "type": "string",
            "nullable": true
          }
        },
        "required": [
          "id",
          "email",
          "name",
          "role",
          "taxId",
          "pixKey"
        ]
      },
      "UpdateProfileDto": {
        "type": "object",
        "properties": {
          "taxId": {
            "type": "string"
          },
          "pixKey": {
            "type": "string",
            "minLength": 1,
            "maxLength": 140
          }
        },
        "required": [
          "taxId",
          "pixKey"
        ]
      },
      "IssueChallengeDto": {
        "type": "object",
        "properties": {}
      },
      "ChallengeResponseDto": {
        "type": "object",
        "properties": {
          "challengeId": {
            "type": "string"
          },
          "word": {
            "type": "string"
          },
          "number": {
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991
          },
          "gesture": {
            "type": "string"
          },
          "nonce": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
          }
        },
        "required": [
          "challengeId",
          "word",
          "number",
          "gesture",
          "nonce",
          "expiresAt"
        ]
      },
      "WeighInSummaryDto": {
        "type": "object",
        "properties": {
          "weighinId": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "baseline",
              "mid",
              "final"
            ]
          },
          "weightKg": {
            "type": "number"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "blocked",
              "in_review",
              "approved",
              "rejected",
              "recapture"
            ]
          },
          "lossPerWeekKg": {
            "type": "number",
            "nullable": true
          },
          "betId": {
            "type": "string",
            "nullable": true
          },
          "capturedAt": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
          }
        },
        "required": [
          "weighinId",
          "kind",
          "weightKg",
          "status",
          "lossPerWeekKg",
          "betId",
          "capturedAt"
        ]
      },
      "StartWeighInDto": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "baseline",
              "mid",
              "final"
            ]
          },
          "betId": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
            "nullable": true
          },
          "contentType": {
            "default": "video/mp4",
            "type": "string"
          }
        },
        "required": [
          "kind"
        ]
      },
      "StartWeighInResponseDto": {
        "type": "object",
        "properties": {
          "challenge": {
            "type": "object",
            "properties": {
              "challengeId": {
                "type": "string"
              },
              "word": {
                "type": "string"
              },
              "number": {
                "type": "integer",
                "minimum": -9007199254740991,
                "maximum": 9007199254740991
              },
              "gesture": {
                "type": "string"
              },
              "nonce": {
                "type": "string"
              },
              "expiresAt": {
                "type": "string",
                "format": "date-time",
                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
              }
            },
            "required": [
              "challengeId",
              "word",
              "number",
              "gesture",
              "nonce",
              "expiresAt"
            ]
          },
          "upload": {
            "type": "object",
            "properties": {
              "url": {
                "type": "string"
              },
              "objectKey": {
                "type": "string"
              },
              "expiresAt": {
                "type": "string",
                "format": "date-time",
                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
              },
              "requiredHeaders": {
                "type": "object",
                "additionalProperties": {
                  "type": "string"
                }
              }
            },
            "required": [
              "url",
              "objectKey",
              "expiresAt"
            ]
          }
        },
        "required": [
          "challenge",
          "upload"
        ]
      },
      "SubmitWeighInDto": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "baseline",
              "mid",
              "final"
            ]
          },
          "betId": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
            "nullable": true
          },
          "weightKg": {
            "type": "number",
            "exclusiveMinimum": true,
            "maximum": 500,
            "minimum": 0
          },
          "nonce": {
            "type": "string",
            "minLength": 1
          },
          "videoObjectKey": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "kind",
          "weightKg",
          "nonce",
          "videoObjectKey"
        ]
      },
      "SubmitWeighInResponseDto": {
        "type": "object",
        "properties": {
          "weighinId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "blocked",
              "in_review",
              "approved",
              "rejected",
              "recapture"
            ]
          },
          "lossPerWeekKg": {
            "type": "number",
            "nullable": true
          }
        },
        "required": [
          "weighinId",
          "status",
          "lossPerWeekKg"
        ]
      },
      "ReviewQueueEntryDto": {
        "type": "object",
        "properties": {
          "weighinId": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "userName": {
            "type": "string",
            "nullable": true
          },
          "kind": {
            "type": "string",
            "enum": [
              "baseline",
              "mid",
              "final"
            ]
          },
          "weightKg": {
            "type": "number"
          },
          "lossPerWeekKg": {
            "type": "number",
            "nullable": true
          },
          "capturedAt": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
          },
          "reviewId": {
            "type": "string",
            "nullable": true
          },
          "videoUrl": {
            "type": "string"
          }
        },

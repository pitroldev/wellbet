{
  "openapi": "3.0.0",
  "paths": {
    "/api/health": {
      "get": {
        "operationId": "HealthController_check",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Liveness/readiness da API.",
        "tags": [
          "health"
        ]
      }
    },
    "/api/me": {
      "get": {
        "operationId": "IdentityController_me",
        "parameters": [],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Perfil do usuário autenticado.",
        "tags": [
          "identity"
        ]
      }
    },
    "/api/me/profile": {
      "put": {
        "operationId": "IdentityController_setProfile",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateProfileDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Define CPF/CNPJ e chave Pix (necessários para apostar e sacar).",
        "tags": [
          "identity"
        ]
      }
    },
    "/api/challenges": {
      "post": {
        "operationId": "ChallengeController_issue",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IssueChallengeDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "summary": "Emite um código dinâmico para a captura.",
        "tags": [
          "challenge"
        ]
      }
    },
    "/api/weighins": {
      "get": {
        "operationId": "WeighInController_list",
        "parameters": [
          {
            "name": "kind",
            "required": false,
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "baseline",
                "mid",
                "final"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/WeighInSummaryDto"
                  }
                }
              }
            }
          }
        },
        "summary": "Histórico de pesagens do usuário autenticado.",
        "tags": [
          "weighin"
        ]
      },
      "post": {
        "operationId": "WeighInController_submit",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitWeighInDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "summary": "Submete a pesagem capturada.",
        "tags": [
          "weighin"
        ]
      }
    },
    "/api/weighins/start": {
      "post": {
        "operationId": "WeighInController_start",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StartWeighInDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "summary": "Abre uma sessão de captura (código dinâmico + URL de upload).",
        "tags": [
          "weighin"
        ]
      }
    },
    "/api/reviews/queue": {
      "get": {
        "operationId": "ReviewController_queue",
        "parameters": [
          {
            "name": "limit",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 1,
              "maximum": 200,
              "default": 50,
              "type": "integer"
            }
          },
          {
            "name": "offset",
            "required": false,
            "in": "query",
            "schema": {
              "minimum": 0,
              "maximum": 9007199254740991,
              "default": 0,
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ReviewQueueEntryDto"
                  }
                }
              }
            }
          }
        },
        "summary": "Fila de revisão humana (pesagens in_review).",
        "tags": [
          "review"
        ]
      }
    },
    "/api/reviews/verdict": {
      "post": {
        "operationId": "ReviewController_verdict",
        "parameters": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitVerdictDto"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VerdictResponseDto"
                }
              }
            }
          }
        },
        "summary": "Registra o veredito da revisão humana.",
        "tags": [
          "review"
        ]
      }
    },
    "/api/bets": {
      "get": {
        "operationId": "BetController_list",
        "parameters": [],
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BetSummaryDto"
                  }
                }
              }
            }
          }
        },
        "summary": "Lista as apostas do usuário autenticado.",
        "tags": [
          "bet"
        ]
      },
      "post": {
        "operationId": "BetController_place",
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "description": "Chave de idempotência (escrita financeira).",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PlaceBetDto"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": ""
          }
        },
        "summary": "Cria uma aposta (idempotente).",
        "tags": [
          "bet"
        ]
      }
    },
    "/api/bets/{id}": {
      "get": {
        "operationId": "BetController_detail",
        "parameters": [
          {
            "name": "id",
            "required": true,
            "in": "path",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": ""
          }
        },
        "summary": "Detalhe de uma aposta (BR Code se pendente de pagamento).",
        "tags": [
          "bet"
        ]
      }
    }
  },
  "info": {
    "title": "Charya API",
    "description": "Backend Charya Bet — pesagem, desafio, revisão, aposta.",
    "version": "0.0.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "cookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "better-auth.session_token"
      }
    },
    "schemas": {
      "UpdateProfileDto": {
        "type": "object",
        "properties": {
          "taxId": {
            "type": "string"
          },
          "pixKey": {
            "type": "string",
            "minLength": 1,
            "maxLength": 140
          }
        },
        "required": [
          "taxId",
          "pixKey"
        ]
      },
      "IssueChallengeDto": {
        "type": "object",
        "properties": {}
      },
      "WeighInSummaryDto": {
        "type": "object",
        "properties": {
          "weighinId": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "baseline",
              "mid",
              "final"
            ]
          },
          "weightKg": {
            "type": "number"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "blocked",
              "in_review",
              "approved",
              "rejected",
              "recapture"
            ]
          },
          "lossPerWeekKg": {
            "type": "number",
            "nullable": true
          },
          "betId": {
            "type": "string",
            "nullable": true
          },
          "capturedAt": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
          }
        },
        "required": [
          "weighinId",
          "kind",
          "weightKg",
          "status",
          "lossPerWeekKg",
          "betId",
          "capturedAt"
        ]
      },
      "StartWeighInDto": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "baseline",
              "mid",
              "final"
            ]
          },
          "betId": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
            "nullable": true
          },
          "contentType": {
            "default": "video/mp4",
            "type": "string"
          }
        },
        "required": [
          "kind"
        ]
      },
      "SubmitWeighInDto": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "baseline",
              "mid",
              "final"
            ]
          },
          "betId": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$",
            "nullable": true
          },
          "weightKg": {
            "type": "number",
            "exclusiveMinimum": true,
            "maximum": 500,
            "minimum": 0
          },
          "nonce": {
            "type": "string",
            "minLength": 1
          },
          "videoObjectKey": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "kind",
          "weightKg",
          "nonce",
          "videoObjectKey"
        ]
      },
      "ReviewQueueEntryDto": {
        "type": "object",
        "properties": {
          "weighinId": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "userName": {
            "type": "string",
            "nullable": true
          },
          "kind": {
            "type": "string",
            "enum": [
              "baseline",
              "mid",
              "final"
            ]
          },
          "weightKg": {
            "type": "number"
          },
          "lossPerWeekKg": {
            "type": "number",
            "nullable": true
          },
          "capturedAt": {
            "type": "string",
            "format": "date-time",
            "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
          },
          "reviewId": {
            "type": "string",
            "nullable": true
          },
          "videoUrl": {
            "type": "string"
          }
        },
        "required": [
          "weighinId",
          "userId",
          "userName",
          "kind",
          "weightKg",
          "lossPerWeekKg",
          "capturedAt",
          "reviewId",
          "videoUrl"
        ]
      },
      "SubmitVerdictDto": {
        "type": "object",
        "properties": {
          "weighinId": {
            "type": "string",
            "format": "uuid",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|00000000-0000-0000-0000-000000000000|ffffffff-ffff-ffff-ffff-ffffffffffff)$"
          },
          "verdict": {
            "type": "string",
            "enum": [
              "approved",
              "pending",
              "rejected"
            ]
          },
          "reason": {
            "type": "string",
            "maxLength": 2000,
            "nullable": true
          },
          "failedChecks": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "freshness",
                "continuous_video",
                "scale_zero",
                "floor_scene",
                "no_body_trick",
                "display_integrity",
                "same_person",
                "plausibility"
              ]
            },
            "nullable": true
          }
        },
        "required": [
          "weighinId",
          "verdict"
        ]
      },
      "VerdictResponseDto": {
        "type": "object",
        "properties": {
          "reviewId": {
            "type": "string"
          },
          "weighinId": {
            "type": "string"
          },
          "verdict": {
            "type": "string",
            "enum": [
              "approved",
              "pending",
              "rejected"
            ]
          }
        },
        "required": [
          "reviewId",
          "weighinId",
          "verdict"
        ]
      },
      "BetSummaryDto": {
        "type": "object",
        "properties": {
          "betId": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pending_payment",
              "open",
              "settling",
              "won",
              "lost",
              "voided"
            ]
          },
          "targetWeightKg": {
            "type": "number"
          },
          "startWeightKg": {
            "type": "number",
            "nullable": true
          },
          "stakeAmount": {
            "type": "string"
          },
          "payoutAmount": {
            "type": "string",
            "nullable": true
          },
          "currency": {
            "type": "string"
          }
        },
        "required": [
          "betId",
          "status",
          "targetWeightKg",
          "startWeightKg",
          "stakeAmount",
          "payoutAmount",
          "currency"
        ]
      },
      "PlaceBetDto": {
        "type": "object",
        "properties": {
          "targetWeightKg": {
            "type": "number",
            "exclusiveMinimum": true,
            "maximum": 500,
            "minimum": 0
          },
          "startWeightKg": {
            "type": "number",
            "exclusiveMinimum": 0,
            "maximum": 500,
            "nullable": true
          },
          "stakeAmount": {
            "type": "string",
            "pattern": "^\\d+(\\.\\d{1,2})?$"
          },
          "currency": {
            "default": "BRL",
            "type": "string",
            "minLength": 3,
            "maxLength": 3
          }
        },
        "required": [
          "targetWeightKg",
          "stakeAmount"
        ]
      }
    }
  }
}
# Charya API — subset de variáveis de ambiente (validadas por @charya/env no boot).
# Copie para .env e preencha. NUNCA commitar .env real.

# --- Runtime ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Banco (Postgres) ---
DATABASE_URL=postgres://charya:charya@localhost:5432/charya

# --- Auth (Better Auth >= 1.6.14) ---
# Segredo de assinatura de sessão (gerar com: openssl rand -base64 32)
BETTER_AUTH_SECRET=change-me-in-production
BETTER_AUTH_URL=http://localhost:3000

# --- Storage (R2 via API S3) ---
# No dev local usar MinIO (S3-compatível) para paridade com prod.
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=auto
STORAGE_BUCKET=charya-evidence
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
# URLs pré-assinadas: validade em segundos.
STORAGE_PRESIGN_TTL_SECONDS=900

# --- Observabilidade (OpenTelemetry / OTLP) ---
OTEL_ENABLED=true
OTEL_SERVICE_NAME=charya-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# --- Regra de sanidade (plausibilidade de peso, ver doc de Validação §6) ---
# Perda/semana acima da qual o sistema BLOQUEIA automaticamente (kg/semana).
WEIGHT_HARD_LIMIT_KG_PER_WEEK=4

# --- Desafio dinâmico (código/nonce, ver doc de Validação §4) ---
CHALLENGE_CODE_TTL_SECONDS=120

# Charya — variáveis de ambiente do monorepo (all-in-one para dev local).
# Copie para `.env` e preencha. NUNCA commitar o .env real (ver .gitignore).
# mise carrega este .env no shell de dev (mise.toml → [env] _.file = ".env").
# Os nomes batem o schema canônico de @charya/env (packages/env), validado no
# boot da api. Cada app também tem seu .env.example com o subset relevante:
#   apps/api/.env.example · apps/admin/.env.example · apps/mobile/.env.example

# =========================================================================
# apps/api — Backend NestJS  (validado por @charya/env/server)
# =========================================================================
# Runtime
NODE_ENV=development
PORT=3000
# Nível de log do Pino: trace|debug|info|warn|error|fatal|silent
LOG_LEVEL=debug

# Postgres (Drizzle ORM). Local: docker-compose (Postgres real). Prod: Neon/Cloud SQL.
DATABASE_URL=postgres://charya:charya@localhost:5432/charya

# Better Auth (>= 1.6.14 — ver alerta de segurança na §2 do doc).
# Segredo de sessão/assinatura (>= 32 chars). Gere com: openssl rand -base64 32
BETTER_AUTH_SECRET=changeme-min-32-characters-base64-string
# URL canônica usada pelo Better Auth para callbacks.
BETTER_AUTH_URL=http://localhost:3000

# Storage S3-compatível (AWS SDK v3 → Cloudflare R2). Local: MinIO (docker-compose).
# Vocabulário único STORAGE_* (o adapter já força path-style p/ MinIO).
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=auto
STORAGE_BUCKET=charya-evidence
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
# URLs pré-assinadas: validade em segundos.
STORAGE_PRESIGN_TTL_SECONDS=900

# Fila/jobs pg-boss — usa o próprio Postgres (reaproveita DATABASE_URL).

# Observabilidade — OpenTelemetry (auto-instrumentation → OTLP).
OTEL_ENABLED=true
OTEL_SERVICE_NAME=charya-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Regra dura de sanidade (Validação MVP §6): perda/semana que BLOQUEIA
# automaticamente (kg/semana). Calibrar folgado — só pega o impossível.
WEIGHT_HARD_LIMIT_KG_PER_WEEK=4
# Validade do código dinâmico exibido na captura, em segundos (Validação MVP §4/§11).
CHALLENGE_CODE_TTL_SECONDS=120

# --- Pagamentos (Stark Bank — Pix in/out) ---
# Sandbox no dev. PROJECT_ID/PRIVATE_KEY opcionais (api sobe sem pagamentos);
# em prod vêm do Secret Manager. PRIVATE_KEY = chave EC (PEM) do projeto.
STARKBANK_ENVIRONMENT=sandbox
# STARKBANK_PROJECT_ID=
# STARKBANK_PRIVATE_KEY=
STARKBANK_INVOICE_EXPIRATION_SECONDS=3600

# =========================================================================
# apps/admin — Next.js (console)  | client: @charya/env/client (NEXT_PUBLIC_*)
# Roda em :3001 no dev p/ liberar :3000 da api.
# =========================================================================
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_URL=http://localhost:3000

# =========================================================================
# apps/mobile — Expo / React Native  (EXPO_PUBLIC_* entram no bundle — sem segredos)
# =========================================================================
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_ENV=development
EXPO_PUBLIC_R2_PUBLIC_URL=https://media.charya.dev
# Token de conta Expo p/ EAS (Build/Submit/Update) — usado no CI, não no app.
# EXPO_TOKEN=

# =========================================================================
# CI / Turborepo (remote cache) — usado nos workflows, não em runtime
# =========================================================================
# TURBO_TOKEN=
# TURBO_TEAM=

# =========================================================================
# infra/terraform — OpenTofu (preenchido via Secret Manager/TF vars no CD)
# =========================================================================
# GCP_REGION=southamerica-east1
# ARTIFACT_REGISTRY=southamerica-east1-docker.pkg.dev/charya-prod
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# TF_STATE_BUCKET=charya-tfstate

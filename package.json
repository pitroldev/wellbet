{
  "name": "charya",
  "version": "0.0.0",
  "private": true,
  "description": "Charya Bet — monorepo (api · admin · mobile · packages · infra)",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "setup": "pnpm install && pnpm dev:up && pnpm db:migrate",
    "build": "turbo run build",
    "dev": "turbo run dev --filter=!@charya/mobile",
    "dev:api": "pnpm --filter @charya/api dev",
    "dev:admin": "pnpm --filter @charya/admin dev",
    "dev:mobile": "pnpm --filter @charya/mobile start",
    "dev:up": "docker compose up -d",
    "dev:down": "docker compose down",
    "dev:logs": "docker compose logs -f",
    "dev:reset": "docker compose down -v",
    "db:generate": "pnpm --filter @charya/api db:generate",
    "db:migrate": "pnpm --filter @charya/api db:migrate",
    "db:studio": "pnpm --filter @charya/api db:studio",
    "contracts:generate": "pnpm --filter @charya/contracts generate",
    "lint": "turbo run lint",
    "lint:fast": "oxlint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "knip": "knip",
    "deps:check": "syncpack list-mismatches",
    "deps:fix": "syncpack fix-mismatches",
    "deps:manypkg": "manypkg check",
    "lint:packages": "manypkg check",
    "publint": "pnpm -r --filter './packages/*' exec publint",
    "attw": "pnpm -r --filter './packages/*' exec attw --pack",
    "changeset": "changeset",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/cli": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@manypkg/cli": "^0.25.1",
    "knip": "catalog:",
    "lefthook": "catalog:",
    "oxlint": "catalog:",
    "prettier": "catalog:",
    "publint": "^0.3.14",
    "syncpack": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  }
}

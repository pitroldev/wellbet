{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    // O cliente gerado (Hey API/client-fetch) usa APIs web (fetch, Request,
    // Headers, AbortController, TextDecoderStream) — disponíveis em web (admin)
    // e RN (mobile) e no Node 18+. Precisamos das declarações DOM para tipá-las.
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "tsBuildInfoFile": "dist/.tsbuildinfo"
  },
  // `openapi-ts.config.ts` fica fora de `src` e roda só via tsx/openapi-ts,
  // por isso não entra no `include` do build de produção.
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts"]
}

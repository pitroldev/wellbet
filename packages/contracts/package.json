{
  "name": "@charya/contracts",
  "version": "0.0.0",
  "private": true,
  "description": "Charya Bet — CONTRATO entre apps: OpenAPI emitido pela api → cliente TS tipado gerado por Hey API. Consumido por mobile/admin. Ninguém edita o código gerado à mão; drift quebra o type-check no CI.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "openapi-ts",
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.0"
  },
  "devDependencies": {
    "@charya/config": "workspace:*",
    "@hey-api/openapi-ts": "^0.98.0",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  }
}

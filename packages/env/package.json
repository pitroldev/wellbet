{
  "name": "@charya/env",
  "version": "0.0.0",
  "private": true,
  "description": "Charya — variáveis de ambiente TIPADAS e validadas no boot (t3-env / Standard Schema + Zod 4). Fronteira de env explícita: server vs client.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf dist .tsbuildinfo"
  },
  "dependencies": {
    "@t3-oss/env-core": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@charya/config": "workspace:*",
    "@types/node": "^24.0.0",
    "eslint": "catalog:",
    "typescript": "catalog:"
  }
}
